# Copy this file to .env.local and fill in the values.
# See SETUP.md for where to find each of these.
#
# SECURITY: never put real values in this *.example file — it is committed to
# git. Only your local .env.local (gitignored) should hold real secrets.

# --- Supabase (required) ---
# Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never expose to the browser, never use
# inside client components, never inject into NEXT_PUBLIC_* variables.
# Bypasses Row Level Security entirely. Only use it from trusted server-only
# admin/background code (e.g. AI usage rollups), and never via the anon
# Supabase client in src/lib/supabase/*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Base URL used to build auth redirect/callback links (magic link, OAuth).
# Use your production URL when deployed (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- AI providers (Phase 4, optional for now) ---
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (optional OCR/extraction path): https://console.groq.com/keys
GROQ_API_KEY=
